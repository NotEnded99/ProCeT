                    if region_type == 'safe': F_s.append(simplex)
                    else: F_us.append(simplex)
        return V_s, V_us, F_s, F_us

    current_mesh = initial_mesh
    
    for t in range(max_iters):
        # --- 阶段 1: 全局验证 ---
        if t % k_verify == 0:
            print(f"\n[Iter {t}] 运行 LBP 网格验证与细分...")
            V_safe, V_unsafe, F_safe, F_unsafe = run_verification(current_mesh)
            print(f"  ✓ SAT (保护集): {len(V_safe)+len(V_unsafe)}")
            print(f"  ✗ UNSAT (修复集): {len(F_safe)+len(F_unsafe)}")
            
            if len(F_safe) == 0 and len(F_unsafe) == 0:
                print("恭喜！网络已100%通过安全验证！")
                break
                
        # --- 阶段 2: 提取流形约束 ---
        J = build_jacobian_matrix(model, V_safe, V_unsafe, f_dyn, g_dyn)
        
        # --- 阶段 3: 计算修复意图 ---
        loss, g_raw = compute_repair_loss_and_grad(model, F_unsafe, F_safe, f_dyn, g_dyn)
        
        # --- 阶段 4: ICGAR 流形投影更新 ---
        # 简单的指数衰减 alpha 调度
        alpha = 1.0 * (0.95 ** t) 
        icgar_project_and_update(model, J, g_raw, lr=1e-3, alpha=alpha, k_rank=50)
        
        if t % 5 == 0:
            print(f"  [Repair] Iter {t} | Loss: {loss:.4f} | Alpha: {alpha:.4f}")

    return model
