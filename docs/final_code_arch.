    # (实际工程中，你可能需要重构 lbp_forward 以支持 functional_call)
    
    # 2. 根据区域返回需要求导的标量目标
    lbp_out = lbp_forward_functional(model, params, buffers, simplex)
    if region_type == 'unsafe':
        return lbp_out.output_upper_bound  # 我们要保持 h_max < 0
    else:
        return compute_invariance_lower_bound(lbp_out, simplex, f_dyn, g_dyn) # 保持 min_L >= 0

def build_jacobian_matrix(model, V_safe, V_unsafe, f_dyn, g_dyn):
    params = dict(model.named_parameters())
    buffers = dict(model.named_buffers())
    
    # 构建求解单一单纯形雅可比的函数
    compute_jac = jacrev(eval_bound_for_jac, argnums=0)
    
    J_rows = []
    
    # 收集 V_unsafe 的梯度
    for simplex in V_unsafe:
        jac_dict = compute_jac(params, buffers, model, simplex, 'unsafe', f_dyn, g_dyn)
        grad_vec = torch.cat([g.flatten() for g in jac_dict.values()])
        J_rows.append(grad_vec)
        
    # 收集 V_safe 的梯度
    for simplex in V_safe:
        jac_dict = compute_jac(params, buffers, model, simplex, 'safe', f_dyn, g_dyn)
        grad_vec = torch.cat([g.flatten() for g in jac_dict.values()])
        J_rows.append(grad_vec)
        
    if not J_rows:
        num_params = sum(p.numel() for p in model.parameters())
        return torch.zeros((1, num_params), device=next(model.parameters()).device)
        
    return torch.stack(J_rows)  # Shape: (m, |theta|)
```

#### 模块 4：修复意图与损失计算 (The Repair Objective)
计算 `UNSAT` 集合的 Hinge Loss，提取原始梯度。

```python
def compute_repair_loss_and_grad(model, F_unsafe, F_safe, f_dyn, g_dyn, tol=-1e-12):
    model.zero_grad()
    total_loss = 0.0
    
    # 惩罚不安全区域的违规 (强迫 h_max < 0)
    for simplex in F_unsafe:
        lbp_out = lbp_forward(model, simplex)
        h_max = lbp_out.output_upper_bound
        total_loss += torch.nn.functional.relu(h_max)
        
    # 惩罚安全区域的违规 (强迫 min_L >= tol)
    for simplex in F_safe:
        lbp_out = lbp_forward(model, simplex)
        min_L = compute_invariance_lower_bound(lbp_out, simplex, f_dyn, g_dyn)
        total_loss += torch.nn.functional.relu(tol - min_L)
        
    if total_loss > 0:
        total_loss.backward()
        g_raw = parameters_to_vector([p.grad for p in model.parameters() if p.requires_grad])
    else:
        g_raw = torch.zeros_like(parameters_to_vector(model.parameters()))
        
    return total_loss.item() if isinstance(total_loss, torch.Tensor) else 0.0, g_raw
```

#### 模块 5：SVD 降维与隐式流形投影 (The ICGAR Optimizer)
执行核心的数学投影和参数更新。

```python
def icgar_project_and_update(model, J, g_raw, lr, alpha, k_rank=50):
    # 1. 截断 SVD (防显存爆炸)
    # J shape: (m, |theta|)
    m = J.shape[0]
    effective_k = min(k_rank, m)
    
    if effective_k > 0:
        U, S, V = torch.svd_lowrank(J, q=effective_k)
        V_k = V  # Shape: (|theta|, k)，法向危险空间的正交基
        
        # 2. 隐式投影
        # g_perp = V_k * (V_k^T * g_raw)
        coeffs = torch.matmul(V_k.t(), g_raw)
        g_perp = torch.matmul(V_k, coeffs)
        g_parallel = g_raw - g_perp
    else:
        # 如果没有任何约束，纯梯度下降
        g_parallel = g_raw
        g_perp = torch.zeros_like(g_raw)
        
    # 3. Alpha 调度组合
    g_update = g_parallel + alpha * g_perp
    
    # 4. 更新网络参数
    theta_old = parameters_to_vector(model.parameters())
    theta_new = theta_old - lr * g_update
    vector_to_parameters(theta_new, model.parameters())
```

