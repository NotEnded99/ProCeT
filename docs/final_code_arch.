    if region_type == 'unsafe':
        h_min, h_max = lbp_out.output_lower_bound, lbp_out.output_upper_bound
        
        if h_max < 0:
            return 'SAT', {'h_max': h_max}                 # Case 1: 绝对安全
        elif h_min >= 0:
            return 'UNSAT', {'h_max': h_max}               # Case 2a: 明确违规
        else:
            return 'MAYBE', {}                             # Case 2b: 边界交叉
            
